<!DOCTYPE html>
<html>

<head>
    <title>HDFS GUI Client</title>

    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>

<body>

<div class="container">

    <div class="header">

        <h1>HDFS GUI Client</h1>

        <!-- UPLOAD FILES -->
        <form action="/upload" method="POST" enctype="multipart/form-data">

            <input type="hidden" name="current_path" value="{{ current_path }}">

            <input type="file" name="files" multiple>

            <button type="submit">Upload</button>

        </form>

    </div>

    <div class="actions">

        <!-- CREATE DIRECTORY -->
        <form action="/mkdir" method="POST">

            <input type="hidden" name="current_path" value="{{ current_path }}">

            <input type="text" name="folder_name" placeholder="Folder Name">

            <button type="submit">Create Folder</button>

        </form>

        <!-- CREATE FILE -->
        <form action="/touch" method="POST">

            <input type="hidden" name="current_path" value="{{ current_path }}">

            <input type="text" name="file_name" placeholder="File Name">

            <button type="submit">Create File</button>

        </form>

    </div>

    <div class="path-bar">
        Current Path: {{ current_path }}
    </div>

    <table>

        <thead>

            <tr>

                <th>Name</th>
                <th>Type</th>
                <th>Size</th>
                <th>Permissions</th>
                <th>Actions</th>

            </tr>

        </thead>

        <tbody>

        {% for file in files %}

            <tr>

                <!-- FILE NAME -->
                <td>

                    {% if file.type == "directory" %}

                        <a href="/browse?path={{ file.path }}">
                            📁 {{ file.name }}
                        </a>

                    {% else %}

                        📄 {{ file.name }}

                    {% endif %}

                </td>

                <!-- TYPE -->
                <td>{{ file.type }}</td>

                <!-- SIZE -->
                <td>{{ file.size }}</td>

                <!-- PERMISSIONS -->
                <td>{{ file.permissions }}</td>

                <!-- ACTIONS -->
                <td>

                    <!-- DOWNLOAD + VIEW -->
                    {% if file.type == "file" %}

                        <a href="/download?path={{ file.path }}">
                            Download
                        </a>

                        |

                        <a href="/view?path={{ file.path }}">
                            View
                        </a>

                        |

                    {% endif %}

                    <!-- DELETE -->
                    <form action="/delete"
                          method="POST"
                          style="display:inline;">

                        <input type="hidden"
                               name="path"
                               value="{{ file.path }}">

                        <input type="hidden"
                               name="current_path"
                               value="{{ current_path }}">

                        <button type="submit"
                                onclick="return confirm('Delete this item?')">

                            Delete

                        </button>

                    </form>

                    <br><br>

                    <!-- RENAME -->
                    <form action="/rename"
                          method="POST"
                          style="display:inline;">

                        <input type="hidden"
                               name="old_path"
                               value="{{ file.path }}">

                        <input type="hidden"
                               name="current_path"
                               value="{{ current_path }}">

                        <input type="text"
                               name="new_name"
                               placeholder="New Name">

                        <button type="submit">

                            Rename

                        </button>

                    </form>

                    <br><br>

                    <!-- MOVE -->
                    <form action="/move"
                          method="POST"
                          style="display:inline;">

                        <input type="hidden"
                               name="source"
                               value="{{ file.path }}">

                        <input type="hidden"
                               name="current_path"
                               value="{{ current_path }}">

                        <input type="text"
                               name="destination"
                               placeholder="/destination/path">

                        <button type="submit">

                            Move

                        </button>

                    </form>

                    <br><br>

                    <!-- COPY -->
                    <form action="/copy"
                          method="POST"
                          style="display:inline;">

                        <input type="hidden"
                               name="source"
                               value="{{ file.path }}">

                        <input type="hidden"
                               name="current_path"
                               value="{{ current_path }}">

                        <input type="text"
                               name="destination"
                               placeholder="/copy/path">

                        <button type="submit">

                            Copy

                        </button>

                    </form>

                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

</div>

</body>

</html>
